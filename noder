#!/usr/bin/env node

const fs = require('fs');
const path = require('path');

const args = process.argv.slice(2);

if (args.length === 0 || args[0] === 'list' || args[0] === 'ls') {
    console.log('Available commands:');
    console.log('  list                   Show all available commands');
    console.log('  make:controller        Create a new controller file');
    console.log('  make:middleware        Create a new middleware file');
    console.log('  make:model             Create a new model file');
    console.log('  make:route             Create a new route file');
    console.log('  make:service           Create a new service file');
    console.log('  make:validator         Create a new validator file');
    console.log('  make:config            Create a new config file');
    console.log('  make:migration         Create a new migration file');
    console.log('  make:seeder            Create a new seeder file');
    process.exit(0);
}

const parts = args[0].split(':');
const command = parts[0];
const action = parts[1];

if (action === undefined || action === null) {
    console.log('Action of the method is required.');
    process.exit(1)
}

const actions = {
    controller: { dir: 'Controllers', template: '' },
    middleware: { dir: 'Middleware', template: '' },
    model:      { dir: 'Models', template: '' },
    route:      { dir: 'Routes', template: '' },
    service:    { dir: 'Services', template: '' },
    validator:  { dir: 'Validators', template: '' },
    config:     { dir: 'Config', template: '' },
    migration:  { dir: 'Migrations', template: '' },
    seeder:     { dir: 'Seeders', template: '' },
};

switch(command) {
    case 'make':
        const config = actions[action];

        if (!config) {
            console.log(`Unknown action: ${action}`);
            process.exit(1);
        }

        const names = args.slice(1);

        if (!config.dir || config.dir === '') {
            console.log('Noder config error.');
            process.exit(1)
        }

        const dir = path.join(process.cwd(), 'src', config.dir);

        if (!fs.existsSync(dir)) {
            fs.mkdirSync(dir, { recursive: true });
        }

        names.forEach(name => {
            const filePath = path.join(dir, `${name}.js`);

            if (fs.existsSync(filePath)) {
                console.log(`[SKIP] ${name}.js already exists.`);
                return;
            }

            fs.writeFileSync(filePath, config.template);
            console.log(`[OK] src/${config.dir}/${name}.js`);
        });

        break;
    default:
        console.log('Invalid command.');
}